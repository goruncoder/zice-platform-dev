# Zice Platform — Local Development Environment
# Copy this file to .env and fill in your values

# =============================================================================
# Supabase (Required)
# =============================================================================
# Get these from your Supabase project dashboard: Settings → API
SUPABASE_URL=http://localhost:54322
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
JWT_SECRET=your-jwt-secret

# Database connection (used by zice-core for direct DB access)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# =============================================================================
# Platform Configuration (Optional)
# =============================================================================
PLATFORM_NAME=Zice
ROOT_DOMAIN=zice.io

# =============================================================================
# Service URLs (Optional — defaults work for local dev)
# =============================================================================
API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Slack Notifications (Optional — for CI/CD workflows)
# =============================================================================
# SLACK_PR_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# SLACK_DEPLOY_WEBHOOK_URL=https://hooks.slack.com/services/xxx
