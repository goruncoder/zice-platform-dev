# Zice Platform — Local Development Environment
# Copy this file to .env and fill in your values

# =============================================================================
# Supabase (Required for backend + frontend)
# =============================================================================
# Local defaults below match Supabase CLI local dev (supabase start).
# For cloud Supabase, copy keys from Dashboard → Settings → API.
# For local Supabase CLI: run `supabase status` for URL and keys (do not commit real keys).
SUPABASE_URL=http://localhost:54321
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Database connection (platform-dev Docker Postgres on 54322)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Local dev auth — login without Supabase (make seed + DEV_AUTH_ENABLED=true)
DEV_AUTH_ENABLED=true

# =============================================================================
# Platform Configuration (Optional)
# =============================================================================
PLATFORM_NAME=Zice
ROOT_DOMAIN=zice.io
# Frontend branding (static files in repos/zice-frontend/public/images/)
NEXT_PUBLIC_LOGO_URL=/images/logo-full.png
NEXT_PUBLIC_LOGO_ICON_URL=/images/logo-icon.png

# =============================================================================
# Service URLs (Optional — defaults work for local dev)
# =============================================================================
API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# zice-agent (optional — AI chat service, port 8081)
# =============================================================================
# AGENT_PORT=8081
# ZICE_CORE_URL=http://localhost:8080
# OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# Slack Notifications (Optional — for CI/CD workflows)
# =============================================================================
# SLACK_PR_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# SLACK_DEPLOY_WEBHOOK_URL=https://hooks.slack.com/services/xxx
